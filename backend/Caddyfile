# Port 8080 HTTP configuration (domain-based routing)
http://:8080 {
    # Backend API
    backend.sidechain.live {
        reverse_proxy backend:8787 {
            health_uri /health
            health_interval 10s
            health_status 200
            health_passes 1
            health_fails 5
            transport http {
                dial_timeout 10s
                response_header_timeout 15s
                keepalive 30s
            }
            header_up Connection "upgrade"
            header_up Upgrade "websocket"
            header_up X-Forwarded-Proto "http"
            header_up X-Forwarded-For {http.request.header.X-Forwarded-For}
            header_up X-Forwarded-Proto {http.request.proto}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Real-IP {http.request.header.X-Real-IP}
        }
    }

    # Grafana
    grafana.sidechain.live {
        reverse_proxy grafana:3000 {
            health_uri /api/health
            health_interval 10s
            health_status 200
            health_passes 1
            health_fails 5
            transport http {
                dial_timeout 10s
                response_header_timeout 15s
                expect_continue_timeout 2s
            }
            header_up X-Forwarded-Port "8080"
        }
    }

    # Prometheus
    prometheus.sidechain.live {
        basicauth /* {
            prometheus $2a$14$8acSdF6QjVz2wcN5Q2BI7.VJwfFXrzbb22HPdoHKQzcOyyLRzs7Li
        }
        reverse_proxy prometheus:9090 {
            health_uri /-/healthy
            health_interval 10s
            health_status 200
            health_passes 1
            health_fails 5
            transport http {
                dial_timeout 10s
                response_header_timeout 15s
                expect_continue_timeout 2s
            }
            header_up X-Forwarded-Port "8080"
        }
    }

    # Logging for all
    log {
        output stdout
        format json
    }
}
